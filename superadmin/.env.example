# TheraFlow Superadmin — variabili d'ambiente
# Copia questo file in .env e compila i valori reali.
# VITE_ prefix = esposto al browser. Senza prefix = solo server-side.

# ── App ────────────────────────────────────────────────────────────────────
VITE_APP_NAME=TheraFlow
VITE_APP_URL=http://localhost:5173

# ── API Backend (Ondata 2) ─────────────────────────────────────────────────
# VITE_API_URL=https://api.theraflow.io

# ── Auth (Ondata 2) ────────────────────────────────────────────────────────
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
# Oppure se usi PHP custom:
# VITE_AUTH_URL=https://auth.theraflow.io

# ── Locale ─────────────────────────────────────────────────────────────────
VITE_DEFAULT_LOCALE=it

# ── Feature flags ─────────────────────────────────────────────────────────
VITE_ENABLE_BILLING=false
VITE_ENABLE_DOMAINS=false

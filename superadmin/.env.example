# TheraFlow Superadmin — variabili d'ambiente
# Copia questo file in .env.local e compila i valori reali.
# .env.local NON va in git (è già in .gitignore).
# VITE_ prefix = esposto al browser. Senza prefix = solo server-side.

# ── App ────────────────────────────────────────────────────────────────────
VITE_APP_NAME=TheraFlow
VITE_APP_URL=http://localhost:5173

# ── Supabase (Ondata 2 — backend reale) ───────────────────────────────────
# Trovi entrambi qui: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# ── Locale ─────────────────────────────────────────────────────────────────
VITE_DEFAULT_LOCALE=it

# ── Feature flags ─────────────────────────────────────────────────────────
VITE_ENABLE_BILLING=false
VITE_ENABLE_DOMAINS=false

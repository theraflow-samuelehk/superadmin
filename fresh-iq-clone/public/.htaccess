<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve file esistenti / directory direttamente
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Tutto il resto -> index.html (SPA fallback)
  RewriteRule ^ index.html [L]
</IfModule>
